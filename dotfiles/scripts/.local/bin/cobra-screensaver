#!/usr/bin/env bash
# Cobra screensaver — terminal text effects on ASCII art

screensaver_in_focus() {
  niri msg -j focused-window 2>/dev/null | grep -q '"app_id":"cobra.screensaver"'
}

exit_screensaver() {
  pkill -x tte 2>/dev/null
  pkill -f cobra.screensaver 2>/dev/null
  exit 0
}

trap exit_screensaver SIGINT SIGTERM SIGHUP SIGQUIT

printf '\033]11;rgb:1c/1b/19\007'

tty=$(tty 2>/dev/null)

while true; do
  tte -i ~/.config/cobra/screensaver.txt \
    --frame-rate 120 --canvas-width 0 --canvas-height 0 \
    --reuse-canvas --anchor-canvas c --anchor-text c \
    --random-effect --exclude-effects dev_worm \
    --no-eol --no-restore-cursor &

  while pgrep -t "${tty#/dev/}" -x tte >/dev/null; do
    if read -n1 -t 1 || ! screensaver_in_focus; then
      exit_screensaver
    fi
  done
done
